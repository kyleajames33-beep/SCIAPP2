# ChemQuest Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE
# ============================================
# Supabase project URL (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anonymous key (safe for client-side, RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase service role key (SERVER-ONLY, never prefix with NEXT_PUBLIC_)
# This key bypasses RLS and has full database access
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# APPLICATION
# ============================================
# Node environment (development, production, test)
NODE_ENV="development"

# ============================================
# DEPLOYMENT NOTES
# ============================================
# 1. Get your Supabase credentials from: https://app.supabase.com/project/_/settings/api
# 2. Never commit your actual .env.local file to version control
# 3. In production (Vercel), set these as environment variables in the dashboard
# 4. The SUPABASE_SERVICE_ROLE_KEY must never be exposed to the client